# Local-only Bowdoin HPC settings.
# Copy values into .env.hpc.local if password auth is needed.
# Prefer SSH keys when Bowdoin supports them for this account.

BOWDOIN_HPC_HOST=moosehead.bowdoin.edu
BOWDOIN_HPC_INTERACTIVE_HOST=dover.bowdoin.edu
BOWDOIN_HPC_WEB_PORTAL=hpcweb.bowdoin.edu
BOWDOIN_HPC_USER=
BOWDOIN_HPC_AUTH_MODE=password
BOWDOIN_HPC_PASSWORD=
BOWDOIN_HPC_GPU_PARTITION=gpu
BOWDOIN_HPC_GPU_GRES=gpu:pro6000:1
